KAFKA_BOOTSTRAP_SERVERS=kafka:9092
RAW_FRAMES_TOPIC=raw.frames
DETECTIONS_TOPIC=detections.tracked

VIDEO_PATH=data/example.mp4
VIDEO_NAME=example.mp4
FRAME_RATE_OUT=1
JPEG_QUALITY=80

TRITON_URL=triton:8001
TRITON_MODEL_NAME=yolo_tracker
FRAME_CONSUMER_RENDER_ENABLED=false
FRAME_CONSUMER_RENDER_OUTPUT_DIR=/app/output
FRAME_CONSUMER_RENDER_OUTPUT_FPS=15
FRAME_CONSUMER_RENDER_IMAGE_QUALITY=90
YOLO_CONFIDENCE_THRESHOLD=0.5
TRACKER_TYPE=bytetrack
DETERMINISTIC_MODE=true
DETERMINISTIC_STRICT=true
DETERMINISTIC_SEED=12345
YOLO_DEVICE=cpu
